{
  "name": "jjvs",
  "displayName": "Jujutsu for VSCode",
  "description": "Feature-rich Jujutsu (jj) version control integration for VSCode and Cursor",
  "version": "0.0.1",
  "publisher": "dridus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dridus/jjvs"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "jujutsu",
    "jj",
    "version control",
    "scm",
    "vcs"
  ],
  "activationEvents": [
    "workspaceContains:.jj"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "scm": [
        {
          "id": "jjvs.revisions",
          "name": "Revisions",
          "icon": "$(git-commit)",
          "when": "jjvs:hasRepository"
        },
        {
          "id": "jjvs.details",
          "name": "Revision Details",
          "icon": "$(list-unordered)",
          "when": "jjvs:hasRepository"
        },
        {
          "id": "jjvs.bookmarks",
          "name": "Bookmarks",
          "icon": "$(bookmark)",
          "when": "jjvs:hasRepository"
        },
        {
          "id": "jjvs.oplog",
          "name": "Operation Log",
          "icon": "$(list-unordered)",
          "when": "jjvs:hasRepository"
        },
        {
          "id": "jjvs.evolog",
          "name": "Evolution Log",
          "icon": "$(request-changes)",
          "when": "jjvs:hasRepository"
        }
      ]
    },
    "commands": [
      {
        "command": "jjvs.refresh",
        "title": "Refresh",
        "category": "Jujutsu",
        "icon": "$(refresh)"
      },
      {
        "command": "jjvs.describeWorkingCopy",
        "title": "Describe Working Copy",
        "category": "Jujutsu",
        "icon": "$(edit)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.copyChangeId",
        "title": "Copy Change ID",
        "category": "Jujutsu",
        "enablement": "jjvs:revisionSelected"
      },
      {
        "command": "jjvs.revision.copyCommitId",
        "title": "Copy Commit ID",
        "category": "Jujutsu",
        "enablement": "jjvs:revisionSelected"
      },
      {
        "command": "jjvs.revisions.setRevset",
        "title": "Filter by Revset...",
        "category": "Jujutsu",
        "icon": "$(filter)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.new",
        "title": "New Revision...",
        "category": "Jujutsu",
        "icon": "$(add)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.edit",
        "title": "Edit Revision",
        "category": "Jujutsu",
        "icon": "$(arrow-right)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.abandon",
        "title": "Abandon Revision",
        "category": "Jujutsu",
        "icon": "$(trash)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.describe",
        "title": "Describe Revision...",
        "category": "Jujutsu",
        "icon": "$(edit)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.describeInEditor",
        "title": "Describe Revision in Editor...",
        "category": "Jujutsu",
        "icon": "$(go-to-file)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.duplicate",
        "title": "Duplicate Revision",
        "category": "Jujutsu",
        "icon": "$(copy)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.split",
        "title": "Split Revision...",
        "category": "Jujutsu",
        "icon": "$(split-horizontal)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.squash",
        "title": "Squash Revision...",
        "category": "Jujutsu",
        "icon": "$(fold-down)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.restore",
        "title": "Restore Revision...",
        "category": "Jujutsu",
        "icon": "$(discard)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.absorb",
        "title": "Absorb into Ancestors",
        "category": "Jujutsu",
        "icon": "$(arrow-up)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.revision.revert",
        "title": "Revert Revision...",
        "category": "Jujutsu",
        "icon": "$(history)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.conflict.resolve",
        "title": "Resolve Conflicts...",
        "category": "Jujutsu",
        "icon": "$(tools)",
        "enablement": "jjvs:hasConflicts"
      },
      {
        "command": "jjvs.rebase",
        "title": "Rebase Revision...",
        "category": "Jujutsu",
        "icon": "$(git-merge)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.bookmark.create",
        "title": "Create Bookmark...",
        "category": "Jujutsu",
        "icon": "$(add)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.bookmark.move",
        "title": "Move Bookmark...",
        "category": "Jujutsu",
        "icon": "$(arrow-right)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.bookmark.delete",
        "title": "Delete Bookmark",
        "category": "Jujutsu",
        "icon": "$(trash)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.bookmark.forget",
        "title": "Forget Bookmark",
        "category": "Jujutsu",
        "icon": "$(close)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.bookmark.track",
        "title": "Track Remote Bookmark",
        "category": "Jujutsu",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.bookmark.untrack",
        "title": "Untrack Remote Bookmark",
        "category": "Jujutsu",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.git.push",
        "title": "Push...",
        "category": "Jujutsu",
        "icon": "$(cloud-upload)",
        "enablement": "jjvs:hasRepository && jjvs:isColocated"
      },
      {
        "command": "jjvs.git.fetch",
        "title": "Fetch...",
        "category": "Jujutsu",
        "icon": "$(cloud-download)",
        "enablement": "jjvs:hasRepository && jjvs:isColocated"
      },
      {
        "command": "jjvs.oplog.undo",
        "title": "Undo Last Operation",
        "category": "Jujutsu",
        "icon": "$(discard)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.oplog.restore",
        "title": "Restore to Operation",
        "category": "Jujutsu",
        "icon": "$(history)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.details.openDiff",
        "title": "Open Diff",
        "category": "Jujutsu",
        "icon": "$(diff)",
        "enablement": "jjvs:fileSelected"
      },
      {
        "command": "jjvs.details.restoreFile",
        "title": "Restore File...",
        "category": "Jujutsu",
        "icon": "$(discard)",
        "enablement": "jjvs:fileSelected"
      },
      {
        "command": "jjvs.details.squashFile",
        "title": "Squash File into Parent",
        "category": "Jujutsu",
        "icon": "$(fold-down)",
        "enablement": "jjvs:fileSelected"
      },
      {
        "command": "jjvs.details.splitFile",
        "title": "Split File into New Revision...",
        "category": "Jujutsu",
        "icon": "$(split-horizontal)",
        "enablement": "jjvs:fileSelected"
      },
      {
        "command": "jjvs.details.showFileHistory",
        "title": "Show File History",
        "category": "Jujutsu",
        "icon": "$(history)",
        "enablement": "jjvs:fileSelected"
      },
      {
        "command": "jjvs.preview.show",
        "title": "Show Preview Panel",
        "category": "Jujutsu",
        "icon": "$(preview)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.preview.toggle",
        "title": "Toggle Preview Panel",
        "category": "Jujutsu",
        "icon": "$(preview)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.graph.show",
        "title": "Show Revision Graph",
        "category": "Jujutsu",
        "icon": "$(type-hierarchy)",
        "enablement": "jjvs:hasRepository"
      },
      {
        "command": "jjvs.graph.toggle",
        "title": "Toggle Revision Graph",
        "category": "Jujutsu",
        "icon": "$(type-hierarchy)",
        "enablement": "jjvs:hasRepository"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "jjvs.refresh",
          "when": "scmProvider == jjvs",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "jjvs.refresh",
          "when": "view == jjvs.revisions",
          "group": "navigation"
        },
        {
          "command": "jjvs.revisions.setRevset",
          "when": "view == jjvs.revisions && jjvs:hasRepository",
          "group": "navigation"
        },
        {
          "command": "jjvs.revision.new",
          "when": "view == jjvs.revisions && jjvs:hasRepository",
          "group": "navigation"
        },
        {
          "command": "jjvs.refresh",
          "when": "view == jjvs.bookmarks",
          "group": "navigation"
        },
        {
          "command": "jjvs.bookmark.create",
          "when": "view == jjvs.bookmarks && jjvs:hasRepository",
          "group": "navigation"
        },
        {
          "command": "jjvs.git.push",
          "when": "view == jjvs.bookmarks && jjvs:hasRepository && jjvs:isColocated",
          "group": "navigation"
        },
        {
          "command": "jjvs.git.fetch",
          "when": "view == jjvs.bookmarks && jjvs:hasRepository && jjvs:isColocated",
          "group": "navigation"
        },
        {
          "command": "jjvs.refresh",
          "when": "view == jjvs.oplog",
          "group": "navigation"
        },
        {
          "command": "jjvs.oplog.undo",
          "when": "view == jjvs.oplog && jjvs:hasRepository",
          "group": "navigation"
        },
        {
          "command": "jjvs.preview.toggle",
          "when": "view == jjvs.revisions && jjvs:hasRepository",
          "group": "navigation"
        },
        {
          "command": "jjvs.graph.toggle",
          "when": "view == jjvs.revisions && jjvs:hasRepository",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "jjvs.git.push",
          "when": "jjvs:hasRepository && jjvs:isColocated"
        },
        {
          "command": "jjvs.git.fetch",
          "when": "jjvs:hasRepository && jjvs:isColocated"
        }
      ],
      "view/item/context": [
        {
          "command": "jjvs.revision.new",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/",
          "group": "1_primary@1"
        },
        {
          "command": "jjvs.revision.edit",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && !(viewItem =~ /workingCopy/)",
          "group": "1_primary@2"
        },
        {
          "command": "jjvs.revision.describe",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && !(viewItem =~ /immutable/)",
          "group": "2_modify@1"
        },
        {
          "command": "jjvs.revision.describeInEditor",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && !(viewItem =~ /immutable/)",
          "group": "2_modify@2"
        },
        {
          "command": "jjvs.revision.duplicate",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/",
          "group": "2_modify@3"
        },
        {
          "command": "jjvs.revision.abandon",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && !(viewItem =~ /immutable/)",
          "group": "3_destructive@1"
        },
        {
          "command": "jjvs.revision.split",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && !(viewItem =~ /immutable/)",
          "group": "2_modify@4"
        },
        {
          "command": "jjvs.revision.squash",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && !(viewItem =~ /immutable/)",
          "group": "2_modify@5"
        },
        {
          "command": "jjvs.revision.restore",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && !(viewItem =~ /immutable/)",
          "group": "2_modify@6"
        },
        {
          "command": "jjvs.revision.absorb",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/ && viewItem =~ /workingCopy/",
          "group": "2_modify@7"
        },
        {
          "command": "jjvs.revision.revert",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/",
          "group": "3_destructive@2"
        },
        {
          "command": "jjvs.conflict.resolve",
          "when": "view == jjvs.revisions && viewItem =~ /conflict/",
          "group": "1_primary@3"
        },
        {
          "command": "jjvs.rebase",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/",
          "group": "2_modify@8"
        },
        {
          "command": "jjvs.revision.copyChangeId",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/",
          "group": "9_copy@1"
        },
        {
          "command": "jjvs.revision.copyCommitId",
          "when": "view == jjvs.revisions && viewItem =~ /^revision/",
          "group": "9_copy@2"
        },
        {
          "command": "jjvs.bookmark.move",
          "when": "view == jjvs.bookmarks && viewItem =~ /localBookmark/",
          "group": "1_primary@1"
        },
        {
          "command": "jjvs.bookmark.delete",
          "when": "view == jjvs.bookmarks && viewItem =~ /localBookmark/",
          "group": "3_destructive@1"
        },
        {
          "command": "jjvs.bookmark.forget",
          "when": "view == jjvs.bookmarks && viewItem =~ /localBookmark/",
          "group": "3_destructive@2"
        },
        {
          "command": "jjvs.bookmark.track",
          "when": "view == jjvs.bookmarks && viewItem =~ /isUntracked/",
          "group": "1_primary@1"
        },
        {
          "command": "jjvs.bookmark.untrack",
          "when": "view == jjvs.bookmarks && viewItem =~ /isTracked/",
          "group": "1_primary@1"
        },
        {
          "command": "jjvs.oplog.restore",
          "when": "view == jjvs.oplog && viewItem == operation",
          "group": "1_primary@1"
        },
        {
          "command": "jjvs.details.openDiff",
          "when": "view == jjvs.details && viewItem =~ /^fileChange/",
          "group": "1_primary@1"
        },
        {
          "command": "jjvs.details.restoreFile",
          "when": "view == jjvs.details && viewItem =~ /^fileChange/ && viewItem =~ /mutable/",
          "group": "2_file_ops@1"
        },
        {
          "command": "jjvs.details.squashFile",
          "when": "view == jjvs.details && viewItem =~ /^fileChange/ && viewItem =~ /mutable/",
          "group": "2_file_ops@2"
        },
        {
          "command": "jjvs.details.splitFile",
          "when": "view == jjvs.details && viewItem =~ /^fileChange/ && viewItem =~ /mutable/",
          "group": "2_file_ops@3"
        },
        {
          "command": "jjvs.details.showFileHistory",
          "when": "view == jjvs.details && viewItem =~ /^fileChange/",
          "group": "3_history@1"
        }
      ]
    },
    "keybindings": [
      {
        "key": "n",
        "command": "jjvs.revision.new",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository"
      },
      {
        "key": "e",
        "command": "jjvs.revision.edit",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository && jjvs:revisionSelected"
      },
      {
        "key": "d",
        "command": "jjvs.revision.describe",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository && jjvs:revisionSelected"
      },
      {
        "key": "s",
        "command": "jjvs.revision.split",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository && jjvs:revisionSelected"
      },
      {
        "key": "q",
        "command": "jjvs.revision.squash",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository && jjvs:revisionSelected"
      },
      {
        "key": "a",
        "command": "jjvs.revision.absorb",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository"
      },
      {
        "key": "r",
        "command": "jjvs.conflict.resolve",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasConflicts"
      },
      {
        "key": "b",
        "command": "jjvs.rebase",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository && jjvs:revisionSelected"
      },
      {
        "key": "x",
        "command": "jjvs.revision.abandon",
        "when": "focusedView == 'jjvs.revisions' && jjvs:hasRepository && jjvs:revisionSelected"
      },
      {
        "key": "u",
        "command": "jjvs.oplog.undo",
        "when": "focusedView == 'jjvs.oplog' && jjvs:hasRepository"
      },
      {
        "key": "enter",
        "command": "jjvs.oplog.restore",
        "when": "focusedView == 'jjvs.oplog' && jjvs:hasRepository"
      }
    ],
    "configuration": {
      "title": "Jujutsu for VSCode",
      "properties": {
        "jjvs.jjPath": {
          "type": "string",
          "default": "jj",
          "description": "Path to the jj binary. Defaults to 'jj' (resolved via PATH).",
          "scope": "machine-overridable"
        },
        "jjvs.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "description": "Verbosity level for the Jujutsu output channel.",
          "scope": "window"
        },
        "jjvs.revset": {
          "type": "string",
          "default": "",
          "description": "Default revset expression for the revision log. Leave empty to use jj's default.",
          "scope": "resource"
        },
        "jjvs.logTemplate": {
          "type": "string",
          "default": "",
          "description": "Custom jj log template. When set, overrides the built-in JSON template. For advanced use only.",
          "scope": "resource"
        },
        "jjvs.logLimit": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of revisions to load per batch in the revision log.",
          "scope": "resource"
        },
        "jjvs.oplogLimit": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "maximum": 10000,
          "description": "Maximum number of operations to show in the operation log.",
          "scope": "resource"
        },
        "jjvs.git.defaultRemote": {
          "type": "string",
          "default": "origin",
          "description": "Default remote name for git push/fetch operations. Only relevant for colocated jj+git repositories.",
          "scope": "resource"
        },
        "jjvs.preview.position": {
          "type": "string",
          "enum": [
            "auto",
            "beside",
            "below"
          ],
          "default": "auto",
          "description": "Position of the preview panel showing jj show/diff output.",
          "scope": "window"
        },
        "jjvs.preview.showOnStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the preview panel when the extension activates.",
          "scope": "window"
        },
        "jjvs.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh views when jj repository state changes.",
          "scope": "resource"
        },
        "jjvs.autoRefreshInterval": {
          "type": "number",
          "default": 3000,
          "minimum": 500,
          "description": "Polling fallback interval in milliseconds for auto-refresh when file watching is unavailable.",
          "scope": "resource"
        },
        "jjvs.graphStyle": {
          "type": "string",
          "enum": [
            "text",
            "webview"
          ],
          "default": "text",
          "enumDescriptions": [
            "Show the revision graph as text characters in the tree view (fast, always available)",
            "Show the revision graph as an interactive graphical webview (richer, requires more resources)"
          ],
          "description": "Rendering style for the revision graph.",
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "build:watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "test:integration": "pnpm compile:integration && node ./node_modules/@vscode/test-cli/bin/vscode-test",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "vscode:prepublish": "node esbuild.mjs --production",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@vscode/vsce-sign",
      "keytar"
    ],
    "overrides": {
      "devalue": ">=5.6.4",
      "serialize-javascript": ">=7.0.4",
      "undici": ">=7.24.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "1.105.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "esbuild-svelte": "^0.9.0",
    "prettier": "^3.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
